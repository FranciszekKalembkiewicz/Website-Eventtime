---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHero from '../components/PageHero.astro';
import ExperienceBar from '../components/ExperienceBar.astro';
import ContactForm from '../components/ContactForm.astro';
import ServiceAreaSection from '../components/ServiceAreaSection.astro';
import { site } from '../config/site';
import { getTranslations } from '../i18n';
import { fmt } from '../i18n/utils';

const tr = getTranslations(Astro.currentLocale);
---

<BaseLayout title={tr.meta.oNas.title} description={tr.meta.oNas.description}>
  <PageHero
    title={tr.oNas.heroTitle}
    subtitle={tr.oNas.heroSubtitle}
  />
  <ExperienceBar />

  <section class="py-20 md:py-28">
    <div class="max-w-7xl mx-auto px-4 grid lg:grid-cols-2 gap-14 items-start">
      <div class="reveal">
        <span class="text-xs font-bold uppercase tracking-[0.2em] text-accent mb-3 block">{tr.oNas.historyLabel}</span>
        <h2 class="text-3xl md:text-4xl font-bold text-ink tracking-tight mb-6">{tr.oNas.historyTitle}</h2>
        <p class="text-gray-500 leading-relaxed mb-4">{tr.oNas.historyP1}</p>
        <p class="text-gray-500 leading-relaxed mb-4">{tr.oNas.historyP2}</p>
        <p class="text-gray-500 leading-relaxed mb-4">{tr.oNas.historyP3}</p>
        <p class="text-gray-500 leading-relaxed">{tr.oNas.historyP4}</p>
      </div>
      <div class="reveal space-y-5">
        <div class="rounded-3xl overflow-hidden shadow-2xl shadow-ink/10">
          <img
            src="/images/about-team.jpg"
            alt={tr.oNas.teamImageAlt}
            class="w-full aspect-[4/3] object-cover"
          />
        </div>
        <div class="bento-card rounded-2xl p-6">
          <h3 class="font-bold text-ink mb-4">{tr.common.inShort}</h3>
          <dl class="space-y-3 text-sm">
            <div class="flex justify-between gap-4 border-b border-gray-100 pb-3">
              <dt class="text-gray-400">{tr.common.onMarketSince}</dt>
              <dd class="text-ink font-medium text-right">{fmt(tr.common.overYears, { years: site.yearsOnMarket })}</dd>
            </div>
            <div class="flex justify-between gap-4 border-b border-gray-100 pb-3">
              <dt class="text-gray-400">{tr.common.eventsCount}</dt>
              <dd class="text-ink font-medium text-right">1000+</dd>
            </div>
            <div class="flex justify-between gap-4 border-b border-gray-100 pb-3">
              <dt class="text-gray-400">{tr.common.serviceArea}</dt>
              <dd class="text-ink font-medium text-right">{tr.location}</dd>
            </div>
            <div class="flex justify-between gap-4">
              <dt class="text-gray-400">{tr.common.services}</dt>
              <dd class="text-ink font-medium text-right">{tr.common.servicesList}</dd>
            </div>
          </dl>
        </div>
      </div>
    </div>
  </section>

  <ServiceAreaSection />

  <section id="kontakt" class="py-20 md:py-28 bg-surface scroll-mt-24">
    <div class="max-w-7xl mx-auto px-4 grid lg:grid-cols-2 gap-14">
      <div class="reveal">
        <span class="text-xs font-bold uppercase tracking-[0.2em] text-accent mb-3 block">{tr.common.contact}</span>
        <h2 class="text-3xl md:text-4xl font-bold text-ink tracking-tight mb-4">{tr.common.writeToUs}</h2>
        <p class="text-gray-500 mb-8">{tr.common.contactIntro}</p>
        <ul class="space-y-4">
          <li class="flex items-center gap-3">
            <div class="w-10 h-10 rounded-xl bg-accent-light flex items-center justify-center text-accent">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
              </svg>
            </div>
            <div>
              <p class="text-xs text-gray-400 font-medium">{tr.common.phone}</p>
              <a href={`tel:${site.phone.replace(/\s/g, '')}`} class="text-ink font-semibold hover:text-accent transition-colors">
                {site.phone}
              </a>
            </div>
          </li>
          <li class="flex items-center gap-3">
            <div class="w-10 h-10 rounded-xl bg-accent-light flex items-center justify-center text-accent">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
              </svg>
            </div>
            <div>
              <p class="text-xs text-gray-400 font-medium">E-mail</p>
              <a href={`mailto:${site.email}`} class="text-ink font-semibold hover:text-accent transition-colors">
                {site.email}
              </a>
            </div>
          </li>
        </ul>

        <div class="mt-10 bento-card rounded-2xl p-6">
          <h3 class="font-bold text-ink mb-3">{tr.common.companyData}</h3>
          <ul class="text-sm text-gray-500 space-y-1">
            <li>{site.company.legalName}</li>
            <li>{site.company.address}</li>
            <li>NIP: {site.company.nip}</li>
            <li>REGON: {site.company.regon}</li>
          </ul>
        </div>
      </div>

      <div class="reveal bento-card rounded-2xl p-6 md:p-8">
        <h3 class="font-bold text-ink text-lg mb-6">{tr.common.contactForm}</h3>
        <ContactForm />
      </div>
    </div>
  </section>
</BaseLayout>
