---
interface Step {
  number: string;
  title: string;
  description: string;
}

interface Props {
  title: string;
  steps: Step[];
}

const { title, steps } = Astro.props;
---

<section class="py-20 md:py-28 bg-surface">
  <div class="max-w-7xl mx-auto px-4">
    <h2 class="reveal text-3xl md:text-4xl font-bold text-ink text-center tracking-tight mb-14">
      {title}
    </h2>
    <div class="grid md:grid-cols-3 gap-8">
      {steps.map((step, i) => (
        <div class="reveal text-center" style={`transition-delay: ${i * 100}ms`}>
          <div class="w-14 h-14 mx-auto mb-5 rounded-2xl bg-gradient-to-br from-accent to-violet text-white flex items-center justify-center text-xl font-bold shadow-lg shadow-accent/30">
            {step.number}
          </div>
          <h3 class="font-bold text-ink text-lg mb-2">{step.title}</h3>
          <p class="text-gray-500 text-sm leading-relaxed">{step.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>
