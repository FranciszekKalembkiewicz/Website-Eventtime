---
import { getTranslations } from '../i18n';

const tr = getTranslations(Astro.currentLocale);
---

<div
  id="site-lightbox"
  class="fixed inset-0 z-[200] hidden items-center justify-center p-4 md:p-8"
  role="dialog"
  aria-modal="true"
  aria-hidden="true"
  aria-label={tr.common.lightboxLabel}
>
  <div class="absolute inset-0 bg-ink/90 backdrop-blur-sm" data-lightbox-close></div>

  <button
    type="button"
    class="absolute top-4 right-4 z-10 w-11 h-11 rounded-full bg-white/10 hover:bg-white/20 text-white text-2xl leading-none transition-colors"
    data-lightbox-close
    aria-label={tr.common.close}
  >
    ×
  </button>

  <button
    type="button"
    class="absolute left-2 md:left-6 top-1/2 -translate-y-1/2 z-10 w-11 h-11 rounded-full bg-white/10 hover:bg-white/20 text-white text-3xl leading-none transition-colors hidden"
    data-lightbox-prev
    aria-label={tr.common.lightboxPrev}
  >
    ‹
  </button>

  <button
    type="button"
    class="absolute right-2 md:right-6 top-1/2 -translate-y-1/2 z-10 w-11 h-11 rounded-full bg-white/10 hover:bg-white/20 text-white text-3xl leading-none transition-colors hidden"
    data-lightbox-next
    aria-label={tr.common.lightboxNext}
  >
    ›
  </button>

  <figure class="relative z-[1] max-w-5xl w-full max-h-[85vh] flex flex-col items-center gap-3">
    <img
      class="max-h-[75vh] w-auto max-w-full rounded-2xl shadow-2xl object-contain"
      src=""
      alt=""
      data-lightbox-img
    />
    <figcaption class="text-white/80 text-sm text-center max-w-lg px-4" data-lightbox-caption></figcaption>
  </figure>
</div>

<script>
  type LightboxItem = { src: string; alt: string };

  const overlay = document.getElementById('site-lightbox');
  if (!overlay) throw new Error('Lightbox not found');

  const img = overlay.querySelector<HTMLImageElement>('[data-lightbox-img]');
  const caption = overlay.querySelector<HTMLElement>('[data-lightbox-caption]');
  const prevBtn = overlay.querySelector<HTMLButtonElement>('[data-lightbox-prev]');
  const nextBtn = overlay.querySelector<HTMLButtonElement>('[data-lightbox-next]');

  let group: LightboxItem[] = [];
  let index = 0;

  function collectGroup(groupId: string): LightboxItem[] {
    return [...document.querySelectorAll<HTMLElement>(`[data-lightbox-group="${groupId}"]`)]
      .sort((a, b) => Number(a.dataset.lightboxIndex ?? 0) - Number(b.dataset.lightboxIndex ?? 0))
      .map((el) => ({
        src: el.dataset.lightboxSrc ?? '',
        alt: el.dataset.lightboxAlt ?? '',
      }));
  }

  function showAt(i: number) {
    if (!img || !caption || group.length === 0) return;
    index = i;
    const item = group[index];
    img.src = item.src;
    img.alt = item.alt;
    caption.textContent = item.alt;
    const multi = group.length > 1;
    prevBtn?.classList.toggle('hidden', !multi);
    nextBtn?.classList.toggle('hidden', !multi);
  }

  function open(groupId: string, startIndex: number) {
    group = collectGroup(groupId);
    if (group.length === 0) return;
    showAt(startIndex);
    overlay.classList.remove('hidden');
    overlay.classList.add('flex');
    overlay.setAttribute('aria-hidden', 'false');
    document.body.style.overflow = 'hidden';
  }

  function close() {
    overlay.classList.add('hidden');
    overlay.classList.remove('flex');
    overlay.setAttribute('aria-hidden', 'true');
    document.body.style.overflow = '';
    if (img) img.src = '';
    group = [];
  }

  document.addEventListener('click', (e) => {
    const trigger = (e.target as Element).closest<HTMLElement>('[data-lightbox-group]');
    if (trigger?.dataset.lightboxSrc) {
      e.preventDefault();
      const groupId = trigger.dataset.lightboxGroup ?? '';
      const items = collectGroup(groupId);
      const startIndex = items.findIndex((item) => item.src === trigger.dataset.lightboxSrc);
      open(groupId, Math.max(0, startIndex));
      return;
    }

    if ((e.target as Element).closest('[data-lightbox-close]')) {
      close();
    }
  });

  prevBtn?.addEventListener('click', () => showAt((index - 1 + group.length) % group.length));
  nextBtn?.addEventListener('click', () => showAt((index + 1) % group.length));

  document.addEventListener('keydown', (e) => {
    if (overlay.classList.contains('hidden')) return;
    if (e.key === 'Escape') close();
    if (e.key === 'ArrowLeft') prevBtn?.click();
    if (e.key === 'ArrowRight') nextBtn?.click();
  });
</script>
