---
import { getTranslations } from '../i18n';

const tr = getTranslations(Astro.currentLocale);

interface Props {
  title: string;
  description: string;
  image: string;
  href: string;
  external?: boolean;
  glowColor?: string;
  index?: number;
  imagePosition?: string;
}

const { title, description, image, href, external = false, glowColor = '#e91e8c', index = 0, imagePosition = 'center' } = Astro.props;
---

<a
  href={href}
  target={external ? '_blank' : undefined}
  rel={external ? 'noopener noreferrer' : undefined}
  class="service-glow bento-card group flex flex-col h-full rounded-2xl overflow-hidden reveal"
  style={`--glow-color: ${glowColor}; transition-delay: ${index * 80}ms`}
>
  <div class="relative aspect-[5/4] shrink-0 overflow-hidden bg-ink/5">
    <img
      src={image}
      alt={title}
      class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700"
      style={`object-position: ${imagePosition}`}
    />
    <div class="absolute inset-0 bg-gradient-to-t from-ink/70 via-ink/20 to-transparent"></div>
    <div class="absolute top-4 left-4 w-8 h-0.5 bg-accent rounded-full"></div>
    <div class="absolute bottom-4 left-4 right-4">
      <h3 class="text-xl font-bold text-white">{title}</h3>
    </div>
  </div>
  <div class="relative p-5 z-10 flex flex-col flex-1">
    <p class="text-gray-500 text-sm leading-relaxed mb-3 flex-1 min-h-[4.25rem]">{description}</p>
    <span class="inline-flex items-center gap-1 text-accent text-sm font-semibold group-hover:gap-2 transition-all mt-auto">
      {external ? tr.common.allegro : tr.common.learnMore}
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
      </svg>
    </span>
  </div>
</a>
