---
interface Card {
  id: string;
  title: string;
  description: string;
  image: string;
}

interface Props {
  items: Card[];
  columns?: 2 | 3 | 4;
}

const { items, columns = 3 } = Astro.props;
const gridClass = {
  2: 'sm:grid-cols-2',
  3: 'sm:grid-cols-2 lg:grid-cols-3',
  4: 'sm:grid-cols-2 lg:grid-cols-4',
}[columns];
---

<div class={`grid grid-cols-1 ${gridClass} gap-5 items-stretch`}>
  {items.map((item, i) => (
    <article
      class="reveal bento-card rounded-2xl overflow-hidden group flex flex-col h-full"
      style={`transition-delay: ${(i % 3) * 80}ms`}
    >
      <div class="aspect-[4/3] shrink-0 overflow-hidden relative bg-ink/5">
        <img
          src={item.image}
          alt={item.title}
          class="w-full h-full object-cover object-center group-hover:scale-105 transition-transform duration-700"
        />
        <div class="absolute inset-0 bg-gradient-to-t from-ink/50 to-transparent opacity-50 pointer-events-none"></div>
      </div>
      <div class="p-5 flex flex-col flex-1">
        <h3 class="text-lg font-bold text-ink mb-2 leading-snug min-h-[2.75rem]">{item.title}</h3>
        <p class="text-gray-500 text-sm leading-relaxed flex-1">{item.description}</p>
      </div>
    </article>
  ))}
</div>
