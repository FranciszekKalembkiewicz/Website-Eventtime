---
interface Image {
  id: string;
  src: string;
  alt: string;
}

interface Props {
  images: Image[];
  limit?: number;
  lightbox?: boolean;
  groupId?: string;
}

const { images, limit, lightbox = true, groupId = 'gallery' } = Astro.props;
const displayImages = limit ? images.slice(0, limit) : images;
const lbGroup = `${groupId}-${displayImages.map((i) => i.id).join('-') || 'empty'}`.slice(0, 48);
---

{displayImages.length > 0 ? (
  <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-3 md:gap-4">
    {displayImages.map((image, i) => (
      lightbox ? (
        <button
          type="button"
          class="reveal aspect-square overflow-hidden rounded-2xl group relative cursor-zoom-in text-left"
          style={`transition-delay: ${(i % 4) * 80}ms`}
          data-lightbox-group={lbGroup}
          data-lightbox-src={image.src}
          data-lightbox-alt={image.alt}
          data-lightbox-index={i}
          aria-label={image.alt}
        >
          <img
            src={image.src}
            alt={image.alt}
            class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-700"
            loading="lazy"
          />
          <div class="absolute inset-0 bg-ink/0 group-hover:bg-ink/25 transition-colors duration-300 flex items-center justify-center">
            <span class="opacity-0 group-hover:opacity-100 transition-opacity w-10 h-10 rounded-full bg-white/90 text-ink flex items-center justify-center shadow-lg" aria-hidden="true">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0zM10 7v3m0 0v3m0-3h3m-3 0H7" />
              </svg>
            </span>
          </div>
        </button>
      ) : (
        <div
          class="reveal aspect-square overflow-hidden rounded-2xl group relative"
          style={`transition-delay: ${(i % 4) * 80}ms`}
        >
          <img
            src={image.src}
            alt={image.alt}
            class="w-full h-full object-cover"
            loading="lazy"
          />
        </div>
      )
    ))}
  </div>
) : null}
