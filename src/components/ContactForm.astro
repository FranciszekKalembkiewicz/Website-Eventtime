---
import { site } from '../config/site';
import { getTranslations } from '../i18n';

const tr = getTranslations(Astro.currentLocale);
---

<form
  id="contact-form"
  action={site.formspreeEndpoint}
  method="POST"
  class="space-y-5"
  data-success={tr.common.formSuccess}
  data-error={tr.common.formError}
>
  <div>
    <label for="name" class="block text-sm font-semibold text-ink mb-1.5">{tr.common.name}</label>
    <input
      type="text"
      id="name"
      name="name"
      required
      class="w-full px-4 py-3 bg-surface border border-gray-200 rounded-xl focus:outline-none focus:ring-2 focus:ring-accent/50 focus:border-accent transition-all"
      placeholder={tr.common.namePlaceholder}
    />
  </div>
  <div>
    <label for="email" class="block text-sm font-semibold text-ink mb-1.5">E-mail</label>
    <input
      type="email"
      id="email"
      name="email"
      required
      class="w-full px-4 py-3 bg-surface border border-gray-200 rounded-xl focus:outline-none focus:ring-2 focus:ring-accent/50 focus:border-accent transition-all"
      placeholder={tr.common.emailPlaceholder}
    />
  </div>
  <div>
    <label for="phone" class="block text-sm font-semibold text-ink mb-1.5">{tr.common.phoneOptional}</label>
    <input
      type="tel"
      id="phone"
      name="phone"
      class="w-full px-4 py-3 bg-surface border border-gray-200 rounded-xl focus:outline-none focus:ring-2 focus:ring-accent/50 focus:border-accent transition-all"
      placeholder={tr.common.phonePlaceholder}
    />
  </div>
  <div>
    <label for="message" class="block text-sm font-semibold text-ink mb-1.5">{tr.common.message}</label>
    <textarea
      id="message"
      name="message"
      required
      rows="5"
      class="w-full px-4 py-3 bg-surface border border-gray-200 rounded-xl focus:outline-none focus:ring-2 focus:ring-accent/50 focus:border-accent transition-all resize-y"
      placeholder={tr.common.messagePlaceholder}
    ></textarea>
  </div>
  <button
    type="submit"
    class="btn-primary w-full sm:w-auto px-8 py-3.5 text-white font-semibold rounded-full disabled:opacity-50"
  >
    {tr.common.sendMessage}
  </button>
  <p id="form-status" class="text-sm hidden"></p>
</form>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement;
  const status = document.getElementById('form-status');

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const button = form.querySelector('button[type="submit"]') as HTMLButtonElement;
    button.disabled = true;
    status?.classList.remove('hidden', 'text-green-600', 'text-red-600');

    try {
      const response = await fetch(form.action, {
        method: 'POST',
        body: new FormData(form),
        headers: { Accept: 'application/json' },
      });

      if (response.ok) {
        status!.textContent = form.dataset.success ?? '';
        status!.classList.add('text-green-600');
        form.reset();
      } else {
        throw new Error('submit failed');
      }
    } catch {
      status!.textContent = form.dataset.error ?? '';
      status!.classList.add('text-red-600');
    } finally {
      button.disabled = false;
      status?.classList.remove('hidden');
    }
  });
</script>
