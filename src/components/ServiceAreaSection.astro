---
import { getTranslations } from '../i18n';
import {
  MAP_VIEWBOX,
  czechPath,
  germanyPath,
  polandPath,
  primaryZonePath,
  zielonaGoraPin,
} from '../data/service-area-map';

const tr = getTranslations(Astro.currentLocale);
const sa = tr.serviceArea;
const clipId = 'service-area-clip';
const pinFilterId = 'service-area-pin-shadow';
---

<section class="py-16 md:py-24 bg-surface border-y border-ink/5">
  <div class="max-w-7xl mx-auto px-4">
    <div class="grid lg:grid-cols-2 gap-10 lg:gap-14 items-center">
      <div class="reveal">
        <span class="text-xs font-bold uppercase tracking-[0.2em] text-accent mb-3 block">{sa.badge}</span>
        <h2 class="text-3xl md:text-4xl font-bold text-ink tracking-tight mb-5">{sa.title}</h2>
        <p class="text-gray-500 leading-relaxed mb-4">{sa.description}</p>
        <p class="text-gray-500 leading-relaxed mb-8">{sa.travelNote}</p>

        <ul class="space-y-3 text-sm">
          <li class="flex items-start gap-3">
            <span class="mt-1.5 w-3 h-3 rounded-full shrink-0 bg-accent ring-2 ring-accent/25"></span>
            <span>
              <span class="font-semibold text-ink">{sa.base}</span>
              <span class="text-gray-500"> - {sa.baseDesc}</span>
            </span>
          </li>
          <li class="flex items-start gap-3">
            <span class="mt-1.5 w-3 h-3 rounded-full shrink-0 bg-[#7f1d1d] ring-2 ring-[#7f1d1d]/25"></span>
            <span>
              <span class="font-semibold text-ink">{sa.primaryZone}</span>
              <span class="text-gray-500"> - {sa.primaryZoneDesc}</span>
            </span>
          </li>
          <li class="flex items-start gap-3">
            <span class="mt-1.5 w-3 h-3 rounded-full shrink-0 bg-ink/15 ring-2 ring-ink/10"></span>
            <span>
              <span class="font-semibold text-ink">{sa.nationwide}</span>
              <span class="text-gray-500"> - {sa.nationwideDesc}</span>
            </span>
          </li>
        </ul>
      </div>

      <div class="reveal bento-card rounded-3xl p-5 md:p-7">
        <svg
          viewBox={MAP_VIEWBOX}
          class="w-full h-auto"
          role="img"
          aria-label={sa.mapLabel}
        >
          <defs>
            <clipPath id={clipId}>
              <path d={polandPath} />
              <path d={germanyPath} />
            </clipPath>
            <filter id={pinFilterId} x="-50%" y="-50%" width="200%" height="200%">
              <feDropShadow dx="0" dy="2" stdDeviation="2" flood-opacity="0.25" />
            </filter>
          </defs>

          <path d={germanyPath} fill="#ebe7e2" stroke="#c8c2ba" stroke-width="1.2" stroke-linejoin="round" />
          <path d={czechPath} fill="#f0eeea" stroke="#d4cec6" stroke-width="1" stroke-linejoin="round" />
          <path d={polandPath} fill="#f4f1ed" stroke="#c8c2ba" stroke-width="1.2" stroke-linejoin="round" />

          <path
            d={primaryZonePath}
            fill="#7f1d1d"
            fill-opacity="0.48"
            clip-path={`url(#${clipId})`}
          />

          <g filter={`url(#${pinFilterId})`}>
            <circle cx={zielonaGoraPin.x} cy={zielonaGoraPin.y} r="14" fill="#e91e8c" opacity="0.18" />
            <circle cx={zielonaGoraPin.x} cy={zielonaGoraPin.y} r="6.5" fill="#e91e8c" stroke="#fff" stroke-width="2" />
          </g>
          <text
            x={zielonaGoraPin.x}
            y={zielonaGoraPin.y + 22}
            text-anchor="middle"
            fill="#1a1625"
            font-size="11"
            font-weight="700"
            font-family="system-ui, sans-serif"
          >
            {sa.baseDesc}
          </text>
        </svg>
      </div>
    </div>
  </div>
</section>
