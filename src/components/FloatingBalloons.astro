---
const balloons = [
  { color: '#e91e8c', size: 44, left: '8%', delay: '0s', duration: '14s', drift: '40px', opacity: 0.7 },
  { color: '#7c3aed', size: 36, left: '18%', delay: '3s', duration: '18s', drift: '-25px', opacity: 0.6 },
  { color: '#f4a826', size: 52, left: '75%', delay: '1s', duration: '16s', drift: '-50px', opacity: 0.75 },
  { color: '#38bdf8', size: 32, left: '85%', delay: '5s', duration: '20s', drift: '20px', opacity: 0.55 },
  { color: '#ff6b9d', size: 40, left: '55%', delay: '2s', duration: '15s', drift: '35px', opacity: 0.65 },
  { color: '#a78bfa', size: 28, left: '35%', delay: '7s', duration: '22s', drift: '-15px', opacity: 0.5 },
  { color: '#fbbf24', size: 38, left: '92%', delay: '4s', duration: '17s', drift: '-30px', opacity: 0.6 },
  { color: '#ec4899', size: 46, left: '5%', delay: '9s', duration: '19s', drift: '55px', opacity: 0.7 },
  { color: '#818cf8', size: 34, left: '65%', delay: '6s', duration: '21s', drift: '-40px', opacity: 0.55 },
  { color: '#fb923c', size: 30, left: '45%', delay: '8s', duration: '23s', drift: '25px', opacity: 0.5 },
];
---

<div class="balloon-field" aria-hidden="true">
  {balloons.map((b) => (
    <div
      class="balloon"
      style={`left: ${b.left}; --color: ${b.color}; --size: ${b.size}px; --delay: ${b.delay}; --drift: ${b.drift}; --opacity: ${b.opacity}; animation-duration: ${b.duration}; animation-delay: ${b.delay};`}
    >
      <div class="balloon-body" style={`--color: ${b.color}; --size: ${b.size}px;`}>
        <div class="balloon-string" style={`--delay: ${b.delay};`}></div>
      </div>
    </div>
  ))}
</div>
