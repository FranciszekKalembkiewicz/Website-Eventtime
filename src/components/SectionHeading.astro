---
interface Props {
  label?: string;
  title: string;
  subtitle?: string;
  light?: boolean;
}

const { label, title, subtitle, light = false } = Astro.props;
---

<div class="text-center mb-12 md:mb-16 reveal">
  {label && (
    <span
      class={`inline-block text-xs font-bold uppercase tracking-[0.2em] mb-3 ${light ? 'text-white/70' : 'text-accent'}`}
    >
      {label}
    </span>
  )}
  <h2
    class={`text-3xl md:text-4xl lg:text-5xl font-bold tracking-tight mb-4 ${light ? 'text-white' : 'text-ink'}`}
  >
    {title}
  </h2>
  {subtitle && (
    <p class={`text-base md:text-lg max-w-2xl mx-auto leading-relaxed ${light ? 'text-white/75' : 'text-gray-500'}`}>
      {subtitle}
    </p>
  )}
</div>
