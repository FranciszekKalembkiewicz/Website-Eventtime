---
import { site } from '../config/site';
import { getTranslations } from '../i18n';
import { fmt, localizedUrl } from '../i18n/utils';
import type { Locale } from '../i18n/locales';
import FloatingBalloons from './FloatingBalloons.astro';
import Logo from './Logo.astro';

const locale = (Astro.currentLocale ?? 'pl') as Locale;
const tr = getTranslations(locale);

const slides = ['/images/hero-1.jpg'];
---

<section class="relative min-h-[92vh] flex items-center overflow-hidden hero-mesh">
  <FloatingBalloons />

  <div class="absolute inset-0 opacity-[0.18]" aria-hidden="true">
    {slides.map((src, i) => (
      <img
        src={src}
        alt=""
        class={`hero-bg absolute inset-0 w-full h-full object-cover transition-opacity duration-1000 ${i === 0 ? 'opacity-100' : 'opacity-0'}`}
        data-index={i}
      />
    ))}
  </div>
  <div class="absolute inset-0 bg-ink/30" aria-hidden="true"></div>

  <div class="relative z-10 w-full max-w-7xl mx-auto px-4 py-20 grid lg:grid-cols-2 gap-12 lg:gap-16 items-center">
    <div class="text-center lg:text-left order-2 lg:order-1">
      <div class="fade-up flex flex-wrap gap-2 justify-center lg:justify-start mb-6">
        <span class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full bg-white/10 border border-white/20 text-white/90 text-sm font-medium">
          {fmt(tr.hero.badgeYears, { years: site.yearsOnMarket })}
        </span>
        <span class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full bg-white/10 border border-white/20 text-white/70 text-sm font-medium">
          {tr.location}
        </span>
      </div>

      <p class="fade-up fade-up-delay-1 text-white/80 text-lg md:text-xl font-medium mb-2 tracking-wide">
        {tr.hero.tagline}
      </p>

      <h1 class="fade-up fade-up-delay-2 text-4xl md:text-5xl lg:text-6xl font-bold text-white leading-[1.15] tracking-tight mb-6">
        {tr.hero.titleLine1}<br />
        <span class="text-accent-light underline decoration-accent decoration-4 underline-offset-4">{tr.hero.titleLine2}</span>
      </h1>

      <p class="fade-up fade-up-delay-3 text-white/70 text-base md:text-lg leading-relaxed mb-8 max-w-lg mx-auto lg:mx-0">
        {tr.hero.subtitle}
      </p>

      <div class="fade-up fade-up-delay-3 flex flex-wrap gap-4 justify-center lg:justify-start">
        <a href={`${localizedUrl(locale, '/o-nas')}#kontakt`} class="btn-primary px-7 py-3.5 text-white font-semibold rounded-full text-sm">
          {tr.hero.ctaQuote}
        </a>
        <a href={localizedUrl(locale, '/animacje')} class="btn-ghost px-7 py-3.5 text-white font-semibold rounded-full text-sm">
          {tr.hero.ctaAnimacje}
        </a>
      </div>
    </div>

    <div class="flex justify-center lg:justify-end order-1 lg:order-2">
      <div class="animate-float relative flex items-center justify-center">
        <Logo variant="hero" />
        <div class="absolute -top-3 -right-2 w-9 h-11 bg-gold/90 shadow-lg" style="border-radius: 50% 50% 50% 50% / 55% 55% 45% 45%;" aria-hidden="true"></div>
        <div class="absolute -bottom-1 -left-4 w-7 h-9 bg-accent shadow-lg" style="border-radius: 50% 50% 50% 50% / 55% 55% 45% 45%;" aria-hidden="true"></div>
        <div class="absolute top-1/3 -right-6 w-6 h-8 bg-sky/90 shadow-lg" style="border-radius: 50% 50% 50% 50% / 55% 55% 45% 45%;" aria-hidden="true"></div>
      </div>
    </div>
  </div>

  <div class="absolute bottom-8 left-1/2 -translate-x-1/2 z-10 flex flex-col items-center gap-2 text-white/40">
    <span class="text-xs uppercase tracking-widest">{tr.common.scroll}</span>
    <div class="w-5 h-8 rounded-full border-2 border-white/30 flex justify-center pt-1.5">
      <div class="w-1 h-2 bg-white/50 rounded-full animate-bounce"></div>
    </div>
  </div>
</section>

<script>
  const bgImages = document.querySelectorAll('.hero-bg');
  let bgIndex = 0;

  if (bgImages.length > 1) {
    setInterval(() => {
      bgImages.forEach((img, i) => {
        img.classList.toggle('opacity-100', i === bgIndex);
        img.classList.toggle('opacity-0', i !== bgIndex);
      });
      bgIndex = (bgIndex + 1) % bgImages.length;
    }, 6000);
  }
</script>
