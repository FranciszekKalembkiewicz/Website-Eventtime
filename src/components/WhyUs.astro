---
import SectionHeading from './SectionHeading.astro';
import { getTranslations } from '../i18n';

const tr = getTranslations(Astro.currentLocale);

const colors = [
  'from-pink-500/10 to-violet-500/10',
  'from-violet-500/10 to-sky-500/10',
  'from-amber-500/10 to-pink-500/10',
  'from-sky-500/10 to-violet-500/10',
];
---

<section class="py-20 md:py-28 bg-surface relative overflow-hidden">
  <div class="absolute top-0 right-0 w-96 h-96 bg-accent/5 rounded-full blur-3xl -translate-y-1/2 translate-x-1/2" aria-hidden="true"></div>
  <div class="absolute bottom-0 left-0 w-72 h-72 bg-violet/5 rounded-full blur-3xl translate-y-1/2 -translate-x-1/2" aria-hidden="true"></div>

  <div class="max-w-7xl mx-auto px-4 relative">
    <SectionHeading
      label={tr.whyUs.label}
      title={tr.whyUs.title}
      subtitle={tr.whyUs.subtitle}
    />
    <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-5">
      {tr.whyUs.items.map((reason, i) => (
        <div
          class={`reveal bento-card rounded-2xl p-6 bg-gradient-to-br ${colors[i]}`}
          style={`transition-delay: ${i * 100}ms`}
        >
          <div class="w-10 h-10 rounded-xl bg-accent/10 flex items-center justify-center mb-4">
            <span class="text-accent font-bold text-sm">{String(i + 1).padStart(2, '0')}</span>
          </div>
          <h3 class="font-bold text-ink text-lg mb-2">{reason.title}</h3>
          <p class="text-gray-500 text-sm leading-relaxed">{reason.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>
