---
import { site } from '../config/site';
import { getTranslations } from '../i18n';

const tr = getTranslations(Astro.currentLocale);

const stats = [
  { value: `${site.yearsOnMarket}+`, label: tr.common.yearsOnMarket },
  { value: '1000+', label: tr.common.eventsDone },
  { value: tr.experience.stat3Value, label: tr.experience.stat3Label },
];
---

<section class="bg-ink text-white border-y border-white/5">
  <div class="max-w-7xl mx-auto px-4 py-8 md:py-10">
    <div class="grid grid-cols-1 sm:grid-cols-3 gap-8 text-center sm:text-left">
      {stats.map((stat) => (
        <div class="reveal sm:border-r sm:last:border-r-0 border-white/10 sm:px-6 first:sm:pl-0 last:sm:pr-0">
          <p class={`font-bold text-white tracking-tight ${stat.value.length > 6 ? 'text-xl md:text-2xl' : 'text-2xl md:text-3xl'}`}>{stat.value}</p>
          <p class="text-sm text-white/50 mt-1 leading-snug">{stat.label}</p>
        </div>
      ))}
    </div>
  </div>
</section>
