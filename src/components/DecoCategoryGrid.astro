---
import Gallery from './Gallery.astro';
import type { GalleryImage } from '../data/gallery';

interface Category {
  id: string;
  title: string;
  description: string;
  detail: string;
  image: string;
}

interface Props {
  categories: Category[];
  categoryImages: Record<string, GalleryImage[]>;
  viewExamplesLabel: string;
  closeLabel: string;
  enlargeHint: string;
  noImagesLabel: string;
}

const { categories, categoryImages, viewExamplesLabel, closeLabel, enlargeHint, noImagesLabel } = Astro.props;
const isPlaceholder = (src: string) => src.includes('/placeholders/');
---

<div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-5 items-stretch">
  {categories.map((item, i) => (
    <button
      type="button"
      class="reveal text-left bento-card rounded-2xl overflow-hidden group cursor-pointer hover:ring-2 hover:ring-accent/40 transition-all flex flex-col h-full"
      style={`transition-delay: ${(i % 4) * 80}ms`}
      data-deco-open={item.id}
      aria-haspopup="dialog"
    >
      <div class="aspect-[4/3] shrink-0 overflow-hidden relative bg-ink/5">
        <img
          src={item.image}
          alt={item.title}
          class={`w-full h-full object-cover object-center group-hover:scale-105 transition-transform duration-700 ${isPlaceholder(item.image) ? 'opacity-80' : ''}`}
        />
        <div class="absolute inset-0 bg-gradient-to-t from-ink/60 to-transparent opacity-60 pointer-events-none"></div>
        <span class="absolute bottom-3 left-4 right-4 text-white/90 text-xs font-semibold uppercase tracking-wider">
          {viewExamplesLabel} →
        </span>
      </div>
      <div class="p-5 flex flex-col flex-1">
        <h3 class="text-lg font-bold text-ink mb-2 group-hover:text-accent transition-colors leading-snug min-h-[2.75rem]">
          {item.title}
        </h3>
        <p class="text-gray-500 text-sm leading-relaxed flex-1">{item.description}</p>
      </div>
    </button>
  ))}
</div>

{categories.map((item) => {
  const images = categoryImages[item.id] ?? [];
  return (
    <dialog
      class="deco-category-dialog w-[min(100%,56rem)] max-h-[90vh] overflow-y-auto rounded-3xl border-0 p-0 bg-surface shadow-2xl backdrop:bg-ink/70"
      id={`deco-dialog-${item.id}`}
      aria-labelledby={`deco-dialog-title-${item.id}`}
    >
      <div class="sticky top-0 z-10 flex items-start justify-between gap-4 bg-surface/95 backdrop-blur-sm border-b border-ink/5 px-5 py-4 md:px-8 md:py-5">
        <div>
          <h2 id={`deco-dialog-title-${item.id}`} class="text-xl md:text-2xl font-bold text-ink tracking-tight">
            {item.title}
          </h2>
          <p class="text-gray-400 text-sm mt-1">{enlargeHint}</p>
        </div>
        <button
          type="button"
          class="shrink-0 w-10 h-10 rounded-full bg-ink/5 hover:bg-ink/10 text-ink text-xl leading-none transition-colors"
          data-deco-close
          aria-label={closeLabel}
        >
          ×
        </button>
      </div>

      <div class="px-5 py-5 md:px-8 md:py-6">
        <p class="text-gray-500 leading-relaxed mb-8">{item.detail}</p>
        {images.length > 0 ? (
          <Gallery images={images} groupId={`deco-${item.id}`} />
        ) : (
          <p class="text-gray-400 text-sm italic">{noImagesLabel}</p>
        )}
      </div>
    </dialog>
  );
})}

<script>
  document.querySelectorAll('[data-deco-open]').forEach((btn) => {
    btn.addEventListener('click', () => {
      const id = (btn as HTMLElement).dataset.decoOpen;
      const dialog = document.getElementById(`deco-dialog-${id}`) as HTMLDialogElement | null;
      dialog?.showModal();
    });
  });

  document.querySelectorAll('[data-deco-close]').forEach((btn) => {
    btn.addEventListener('click', () => {
      (btn as HTMLElement).closest('dialog')?.close();
    });
  });

  document.querySelectorAll('.deco-category-dialog').forEach((dialog) => {
    dialog.addEventListener('click', (e) => {
      if (e.target === dialog) (dialog as HTMLDialogElement).close();
    });
  });
</script>
